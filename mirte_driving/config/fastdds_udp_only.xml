<?xml version="1.0" encoding="UTF-8" ?>
<!--
Fast-DDS profile that disables the shared-memory (SHM) transport and uses only
UDPv4.  The MIRTE boot service (mirte-ros) runs as a systemd service and owns
its /dev/shm/fastrtps_* segment+lock files; our user-launched nodes then fail to
open_and_lock those SHM ports ("RTPS_TRANSPORT_SHM ... open_and_lock_file
failed"), which makes intra-host service calls fail intermittently — e.g. the
Nav2 lifecycle manager's get_state request ("async_send_request failed"),
aborting Nav2 bringup, and dropped cmd_vel to the base.

Forcing UDPv4-only sidesteps SHM completely.  Discovery still uses UDP multicast
and data uses UDP unicast, so our nodes still communicate with each other and
with mirte-ros (which advertises SHM+UDP and falls back to the common UDP).

Activated via FASTRTPS_DEFAULT_PROFILES_FILE (set in shuttle.launch.py).
-->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <profiles>
        <transport_descriptors>
            <transport_descriptor>
                <transport_id>udp_only_transport</transport_id>
                <type>UDPv4</type>
            </transport_descriptor>
        </transport_descriptors>

        <participant profile_name="udp_only" is_default_profile="true">
            <rtps>
                <userTransports>
                    <transport_id>udp_only_transport</transport_id>
                </userTransports>
                <!-- Do NOT add the builtin SHM/UDP transports automatically. -->
                <useBuiltinTransports>false</useBuiltinTransports>
            </rtps>
        </participant>
    </profiles>
</dds>
